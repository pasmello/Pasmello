{
    "id": "clock",
    "name": "Clock",
    "version": "0.1.0",
    "description": "A simple clock widget showing current time and date",
    "entry": "index.html",
    "permissions": {
        "network": [],
        "storage": "read-write",
        "clipboard": "none",
        "notifications": false,
        "camera": false,
        "geolocation": false
    },
    "actions": {},
    "widget": {
        "minSize":     { "w": 2, "h": 2 },
        "maxSize":     { "w": 8, "h": 8 },
        "defaultSize": { "w": 4, "h": 4 }
    }
}
